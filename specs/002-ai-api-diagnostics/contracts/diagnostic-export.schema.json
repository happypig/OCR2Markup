{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dila.edu.tw/schemas/diagnostic-export.schema.json",
  "title": "Exported Diagnostic Package",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "sessionId",
    "record"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sessionId": {
      "type": "string"
    },
    "exportReason": {
      "type": "string"
    },
    "record": {
      "type": "object",
      "required": [
        "requestId",
        "platform",
        "endpointSummary",
        "requestSnapshot",
        "failureCategory",
        "guidanceMessageKey",
        "capturedAtEpochMs",
        "redactionApplied"
      ],
      "properties": {
        "requestId": {
          "type": "string"
        },
        "platform": {
          "type": "string",
          "enum": ["windows", "macos"]
        },
        "endpointSummary": {
          "type": "string"
        },
        "requestSnapshot": {
          "type": "string"
        },
        "httpStatus": {
          "type": "integer"
        },
        "serviceErrorBody": {
          "type": "string"
        },
        "failureCategory": {
          "type": "string",
          "enum": [
            "CREDENTIALS",
            "MODEL_ACCESS",
            "MALFORMED_REQUEST",
            "ENDPOINT_COMPATIBILITY",
            "CONNECTIVITY_OR_PROXY",
            "RATE_LIMIT_OR_CAPACITY",
            "UNKNOWN_SERVICE_FAILURE"
          ]
        },
        "guidanceMessageKey": {
          "type": "string"
        },
        "capturedAtEpochMs": {
          "type": "integer",
          "minimum": 1
        },
        "redactionApplied": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
